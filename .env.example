# ============================================================
# PostgreSQL
# ============================================================
POSTGRES_DB=quiz_platform
POSTGRES_USER=quiz_platform_user
POSTGRES_PASSWORD=change_me_strong_password

# ============================================================
# API Service
# ============================================================
API_DEBUG=false

# ============================================================
# LLM Provider
# ============================================================
# Провайдер: g4f (бесплатно, без ключей) | openai | yandexgpt
# По умолчанию g4f — работает сразу без регистрации
LLM_PROVIDER=g4f

# ── OpenAI (только если LLM_PROVIDER=openai) ──────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── YandexGPT (только если LLM_PROVIDER=yandexgpt) ────────
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_MODEL=yandexgpt-lite

# ============================================================
# VK Bot
# ============================================================
VK_TOKEN=vk1.a....
VK_GROUP_ID=123456789
# ID пользователей VK, которые являются суперюзерами (через запятую)
VK_ADMIN_IDS=11111,222222
